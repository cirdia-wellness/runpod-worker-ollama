{
  "tests": [
    {
      "name": "execute_a_prompt",
      "input": {
        "prompt": "Say: Hallo World!"
      },
      "timeout": 120000
    },
    {
      "name" : "tokyo_facts",
      "input": {
        "messages": [
          {
            "role": "user",
            "content": "Identify the city and population of Tokyo."
          }
        ],
        "format": {
          "type": "object",
          "properties": {
            "city": {
              "type": "string"
            },
            "population": {
              "type": "integer"
            }
          },
          "required": [
            "city",
            "population"
          ]
        }
      },
      "timeout": 120000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "OLLAMA_MODEL_NAME",
        "value": "mistral:7b"
      }
    ]
  }
}
